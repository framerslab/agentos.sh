# agentos.sh Environment Variables

# Copy this file to .env.local and update with your values
# .env.local is gitignored and won't be committed

# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Microsoft Clarity Project ID
NEXT_PUBLIC_CLARITY_PROJECT_ID=your-clarity-id

# Giscus blog comments (powered by GitHub Discussions)
#
# Setup:
#   1. Make sure the target repo is public.
#   2. Enable Discussions in repo Settings → General → Features.
#   3. Install the giscus app: https://github.com/apps/giscus
#   4. Run the configurator at https://giscus.app and copy the four
#      values it generates into the env vars below.
#
# When any of NEXT_PUBLIC_GISCUS_REPO / _REPO_ID / _CATEGORY_ID is empty,
# the Comments component renders a friendly "comments not configured"
# stub instead of an empty iframe shell.
NEXT_PUBLIC_GISCUS_REPO=framerslab/agentos.sh
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# These variables are prefixed with NEXT_PUBLIC_ to make them available in the browser.
# Recommendation: set them as deployment environment variables / GitHub Actions secrets
# (so forks don’t accidentally send data to your analytics properties).
